# Production Qdrant settings
MAKEPAD_QDRANT_IMAGE=qdrant/qdrant:v1.15.5
MAKEPAD_QDRANT_HOST=0.0.0.0
MAKEPAD_QDRANT_TELEMETRY_DISABLED=true
MAKEPAD_QDRANT_CODEGRAPH_ENV_FILE=/etc/makepad/qdrant/codegraph.env
MAKEPAD_QDRANT_OPSBRAIN_ENV_FILE=/etc/makepad/qdrant/opsbrain.env
MAKEPAD_QDRANT_CODEGRAPH_DATA_PATH=/var/lib/makepad/qdrant-codegraph
MAKEPAD_QDRANT_CODEGRAPH_HTTP_PORT=6333
MAKEPAD_QDRANT_CODEGRAPH_GRPC_PORT=6334
MAKEPAD_QDRANT_OPSBRAIN_DATA_PATH=/var/lib/makepad/qdrant-opsbrain
MAKEPAD_QDRANT_OPSBRAIN_HTTP_PORT=6343
MAKEPAD_QDRANT_OPSBRAIN_GRPC_PORT=6344
