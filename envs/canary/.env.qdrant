# Canary Qdrant settings
MAKEPAD_QDRANT_IMAGE=qdrant/qdrant:v1.15.5
MAKEPAD_QDRANT_HOST=0.0.0.0
MAKEPAD_QDRANT_TELEMETRY_DISABLED=true
MAKEPAD_QDRANT_CODEGRAPH_ENV_FILE=/etc/makepad/qdrant/codegraph.env
MAKEPAD_QDRANT_OPSBRAIN_ENV_FILE=/etc/makepad/qdrant/opsbrain.env
MAKEPAD_QDRANT_CODEGRAPH_DATA_PATH=/var/lib/makepad/qdrant-codegraph-canary
MAKEPAD_QDRANT_CODEGRAPH_HTTP_PORT=16333
MAKEPAD_QDRANT_CODEGRAPH_GRPC_PORT=16334
MAKEPAD_QDRANT_OPSBRAIN_DATA_PATH=/var/lib/makepad/qdrant-opsbrain-canary
MAKEPAD_QDRANT_OPSBRAIN_HTTP_PORT=16343
MAKEPAD_QDRANT_OPSBRAIN_GRPC_PORT=16344
